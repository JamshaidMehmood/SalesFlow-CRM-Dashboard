{
  "name": "crm-dashboard-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && node --watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma db push --force-reset && node prisma/seed.js",
    "setup:db": "bash ../scripts/setup-db.sh"
  },
  "dependencies": {
    "@faker-js/faker": "^9.8.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
